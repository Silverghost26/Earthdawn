<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Earthdawn.App"
             xmlns:local="using:Earthdawn"
             RequestedThemeVariant="Default"
             xmlns:services="clr-namespace:EarthDawn.Services">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Styles/AppDefaultStyles.axaml"></StyleInclude>
    </Application.Styles>
             
    <Application.Resources>
        <services:StringToImageconverter x:Key="Imageconverter"></services:StringToImageconverter>
        
        <SolidColorBrush x:Key="PrimaryBackground">#9cbff7</SolidColorBrush>
        <SolidColorBrush x:Key="ButtonNavBackground">Transparent</SolidColorBrush>
        <SolidColorBrush x:Key="ButtonPrimaryBackgroundHover">#63f2a1</SolidColorBrush>
    </Application.Resources>
</Application>