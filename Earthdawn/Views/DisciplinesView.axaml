<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Earthdawn.ViewModels"
             x:DataType="vm:DisciplinesViewModel"
             x:Class="Earthdawn.Views.DisciplinesView">
    
    <Design.DataContext><vm:HomeViewModel></vm:HomeViewModel></Design.DataContext>
    <StackPanel>
        <Carousel SelectedIndex="{Binding CurrentIndex}"
        ItemsSource="{Binding Disciplines}"
        Height="900" Width="1800">
            <Carousel.PageTransition>
                <PageSlide Duration="0:00:00.5" Orientation="Horizontal"/>
            </Carousel.PageTransition>
            <Carousel.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10, 0, 5, 0" Classes="background" BorderThickness="5" BorderBrush="Black" CornerRadius="30">
                        <Grid ColumnDefinitions="*, 480, *" RowDefinitions="Auto, 560, *">
                            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Classes="PrimaryHeader" HorizontalAlignment="Center" VerticalAlignment="Top" Content="{Binding Name}"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Label Classes="PrimarySubHeader" Content="Description:" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontWeight="Bold"/>
                                <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Disciplines.Description}" TextWrapping="Wrap" Padding="15,0,20,20" VerticalAlignment="Top"/>
                                <Label Classes="PrimarySubHeader" Content="Half Magic:" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontWeight="Bold"/>
                                <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Disciplines.HalfMagic}" TextWrapping="Wrap" Padding="15,0,20,20"/>
                                <Label Classes="PrimarySubHeader" Content="Starting Abilities:" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontWeight="Bold"/>
                                <TextBlock Classes="PrimaryDescriptionText" Text="{Binding First}" TextWrapping="Wrap" Padding="15,0,20,0"/>
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock Classes="PrimaryDescriptionText" Text="Durability: " Padding="15,0,5,20"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Disciplines.Durability}" TextWrapping="Wrap" Padding="15,0,20,20"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="20" Classes="PortraitBackground">
                                <StackPanel VerticalAlignment="Center">
                                    <Image 
                                        VerticalAlignment="Top" HorizontalAlignment="Center"
                                        Source="{Binding ImagePath, Converter={StaticResource Imageconverter}}"
                                        Height="450">
                                    </Image>
                                    <Label Classes="PictureBoxHeader" Content="Primary Attributes" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Classes="PictureBoxText" Text="{Binding Disciplines.ImportantAttributes}" TextWrapping="Wrap" Padding="0,2,0,10" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" Grid.Column="2" RowDefinitions="*, *, *, *" ColumnDefinitions="*" HorizontalAlignment="Center">
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <Label Classes="PrimarySubHeader" Content="Novice Optional Talents" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding NoviceOptions}" TextWrapping="Wrap" Padding="20 0 10 0"/>
                                </StackPanel>
                                    <StackPanel Grid.Row="1">
                                        <Label Classes="PrimarySubHeader" Content="Journeyman Optional Talents" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding JourneymanOptions}" TextWrapping="Wrap" Padding="20 0 10 0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2">
                                    <Label Classes="PrimarySubHeader" Content="Warden Optional Talents" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WardenOptions}" TextWrapping="Wrap" Padding="20 0 10 0"/>
                                    </StackPanel>
                                <StackPanel Grid.Row="3">
                                    <Label Classes="PrimarySubHeader" Content="Master Optional Talents" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding MasterOptions}" TextWrapping="Wrap" Padding="20 0 10 0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </Carousel.ItemTemplate>
        </Carousel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="100">
            <Button Content = "Previous" Command="{Binding PreviousCommand}"/>
            <Button Content = "Select Discipline" Command="{Binding ApplyDisciplineValuesCommand}"/>
            <Button Content = "Next" Command="{Binding NextCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
