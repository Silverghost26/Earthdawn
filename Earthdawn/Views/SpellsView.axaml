<!-- Earthdawn/Views/SpellsView.axaml -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Earthdawn.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:SpellsViewModel"
             x:Class="Earthdawn.Views.SpellsView">

    <Design.DataContext><vm:HomeViewModel></vm:HomeViewModel></Design.DataContext>

    <StackPanel Orientation="Vertical" Margin="20">
        <TextBlock Text="Spells" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        <!-- Circle 1 Spells Carousel -->
        <Border Classes="background" BorderBrush="Black" BorderThickness="5" CornerRadius="30" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <Label Content="Circle 1 Spells" Classes="PrimarySubHeader" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <Carousel SelectedIndex="{Binding CircleOneCurrentIndex}" 
                            ItemsSource="{Binding CircleOneSpells.Spells}" 
                            Width="1800" Height="300">
                    <Carousel.PageTransition>
                        <PageSlide Duration="0:00:00.5" Orientation="Horizontal"/>
                    </Carousel.PageTransition>
                    <Carousel.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="200, *" RowDefinitions="40, Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Classes="PrimaryDescriptionText" Text="{Binding Name}" HorizontalAlignment="Center" Padding="0 10 0 0"/>
                                <Border Grid.Column="0" Grid.Row="1" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Padding="20">
                                    <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left">
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Threads, StringFormat='Threads: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Casting, StringFormat='Casting: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Duration, StringFormat='Duration: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Effect, StringFormat='Effect: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Range, StringFormat='Range: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding AOE, StringFormat='AOE: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WeaveAdditional, StringFormat='Weave Additional: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WeaveReAttune, StringFormat='Weave ReAttune: {0}'}"></TextBlock>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Classes="PrimaryDescriptionText" Text="Description:" TextWrapping="Wrap" Margin="60,5,0,0"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Description}" TextWrapping="Wrap" Margin="60, 2, 0 0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </Carousel.ItemTemplate>
                </Carousel>
                
                <!-- Navigation Buttons for Circle 1 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,10,0,0">
                    <Button Content="Previous" 
                            Command="{Binding PreviousCircleOneCommand}"
                            Width="80" Height="30"/>
                    <Button Content="Next" 
                            Command="{Binding NextCircleOneCommand}"
                            Width="80" Height="30"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Circle 2 Spells Carousel -->
        <Border Classes="background" BorderBrush="Black" BorderThickness="5" CornerRadius="30" Padding="20">
            <StackPanel>
                <Label Content="Circle 2 Spells" Classes="PrimarySubHeader" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <Carousel SelectedIndex="{Binding CircleTwoCurrentIndex}" 
                          ItemsSource="{Binding CircleTwoSpells.Spells}" 
                          Width="1800" Height="275">
                    <Carousel.PageTransition>
                        <PageSlide Duration="0:00:00.5" Orientation="Horizontal"/>
                    </Carousel.PageTransition>
                <Carousel.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="200, *" RowDefinitions="40, Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Classes="PrimaryDescriptionText" Text="{Binding Name}" HorizontalAlignment="Center" Padding="0 10 0 0"/>
                                <Border Grid.Column="0" Grid.Row="1" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Padding="20">
                                    <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left">
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Threads, StringFormat='Threads: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Casting, StringFormat='Casting: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Duration, StringFormat='Duration: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Effect, StringFormat='Effect: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Range, StringFormat='Range: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding AOE, StringFormat='AOE: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WeaveAdditional, StringFormat='Weave Additional: {0}'}"></TextBlock>
                                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WeaveReAttune, StringFormat='Weave ReAttune: {0}'}"></TextBlock>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Classes="PrimaryDescriptionText" Text="Description:" TextWrapping="Wrap" Margin="60,5,0,0"/>
                                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Description}" TextWrapping="Wrap" Margin="60, 2, 0 0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </Carousel.ItemTemplate>
                </Carousel>
                
                <!-- Navigation Buttons for Circle 2 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,10,0,0">
                    <Button Content="Previous" 
                            Command="{Binding PreviousCircleTwoCommand}"
                            Width="80" Height="30"/>
                    <Button Content="Next" 
                            Command="{Binding NextCircleTwoCommand}"
                            Width="80" Height="30"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
