<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Earthdawn.ViewModels"
             x:DataType="vm:HomeViewModel"
             x:Class="Earthdawn.Views.HomeView">
    
    <Design.DataContext><vm:HomeViewModel></vm:HomeViewModel></Design.DataContext>
    
    <StackPanel VerticalAlignment="Center">
        <Button HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" FontSize="30" Content="Character Creation" Background="CornflowerBlue" HorizontalContentAlignment="Center"></Button>
    </StackPanel>
</UserControl>
