<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Earthdawn.ViewModels"
             xmlns:models="clr-namespace:Earthdawn.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:CharacterCustomizationsViewModel"
             x:Class="Earthdawn.Views.CharacterCustomizationsView">
    
    <Design.DataContext><vm:HomeViewModel></vm:HomeViewModel></Design.DataContext>
    <StackPanel Spacing="5" Width="1900">
        <Border Classes="background" CornerRadius="30" Padding="20">
            <StackPanel Spacing="5">
                <Label Classes="PrimarySubHeader" Content="Attributes" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                <Grid ColumnDefinitions="Auto,Auto,Auto,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto, Auto">
                    <Label Grid.Row="0" Grid.Column="0" Classes="PrimaryText" HorizontalAlignment="Left" VerticalAlignment="Center" Content="Current Attributes" ></Label>
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Dexterity"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Dexterity"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Dexterity, StringFormat='Dexterity:     {0}'}" FontSize="20"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Strength"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Strength"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Strength, StringFormat='Strength:      {0}'}" FontSize="20" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Toughness"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Toughness"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Toughness, StringFormat='Toughness:  {0}'}" FontSize="20" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Perception"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Perception"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Perception, StringFormat='Perception:   {0} '}" FontSize="20"/>
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Willpower"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Willpower"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Willpower, StringFormat='Willpower:   {0}'}" FontSize="20"/>
                    </StackPanel>
                    <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="-" Width="30" Height="30" Command="{Binding DecrementAttributeCommand}" CommandParameter="Charisma"/>
                        <Button Content="+" Width="30" Height="30" Command="{Binding IncrementAttributeCommand}" CommandParameter="Charisma"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Charisma, StringFormat='Charisma:    {0}'}" FontSize="20"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding DexIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding DexDecrementCost}" FontSize="20" Padding="5 0 0 0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding StrIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding StrDecrementCost}" FontSize="20" Padding="5 0 5 0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding TouIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding TouDecrementCost}" FontSize="20" Padding="5 0 5 0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding PerIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding PerDecrementCost}" FontSize="20" Padding="5 0 5 0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WilIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WilDecrementCost}" FontSize="20" Padding="5 0 5 0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding ChrIncrementCost}" FontSize="20" Padding="15 0 5 0"/>
                        <Label Classes="PrimaryText" Content="|" FontSize="20" Padding="3 0 3 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding ChrDecrementCost}" FontSize="20" Padding="5 0 5 0"/>
                    </StackPanel>
    
                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Center" Grid.ColumnSpan="2" Grid.RowSpan="3">
                        <Label Classes="PrimaryText" Content="Remaining Attribute Points:" Padding="20 0 5 10" FontSize="30"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding RemainingAttributePoints}" FontSize="30" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
                        <Label Classes="PrimaryText" Content="{Binding RacialKarma, StringFormat='Starting Karma: ({0})'}" FontSize="20" Padding="100 0 5 10"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Karma}" FontSize="20"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding Initiative, StringFormat='Initiative: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding PhysicalDefense, StringFormat='PhysicalDefense: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="5" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding MysticDefense, StringFormat='MysticDefense: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding SocialDefense, StringFormat='SocialDefense: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="5" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding UnconsciousRating, StringFormat='UnconsciousRating: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding DeathRating, StringFormat='DeathRating: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="5" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding WoundThreshold, StringFormat='WoundThreshold: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding RecoveryTests, StringFormat='RecoveryTests: {0}'}" FontSize="20" Padding="100 0 5 10"/>
                    </StackPanel>                                                                                    
                </Grid>
            </StackPanel>
        </Border>
        <Border Classes="background" CornerRadius="30">
            <Grid ColumnDefinitions="*,*,*,Auto" RowDefinitions="Auto,*">
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Classes="PrimarySubHeader" Content="Talents" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Classes="PrimaryDescriptionText" Text="Selected Optional Talent" FontSize="25" HorizontalAlignment="Center"/>
                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding SelectedOptionalTalent}" FontSize="20" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="-" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0 0 12 0"/>
                        <Button Content="+" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="12 0 0 0 "/>
                    </StackPanel>
                </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <Label Classes="PrimaryText" Content="Discipline Talents" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="25"/>
                <StackPanel Orientation="Horizontal">
                    <ListBox ItemsSource="{Binding DisciplineTalents}" Background="Transparent" Margin="0, 0, 0, 0" Padding="0"
                             SelectedItem="{Binding SelectedCharacterTalent}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Talent">
                                <DockPanel LastChildFill="True">
                                    <Button Content="-"
                                            Command="{Binding $parent[ListBox].((vm:CharacterCustomizationsViewModel)DataContext).TalentDecreaseButtonClickedCommand}"
                                            CommandParameter="{Binding}"
                                            DockPanel.Dock="Left" Width="30" Height="30" VerticalAlignment="Center"/>
                                    <Button Content="+"
                                            Command="{Binding $parent[ListBox].((vm:CharacterCustomizationsViewModel)DataContext).TalentIncreaseButtonClickedCommand}"
                                            CommandParameter="{Binding}"
                                            DockPanel.Dock="Left" Width="30" Height="30" VerticalAlignment="Center" />
                                    <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Name}" DockPanel.Dock="Left" Padding="5 0 0 0"/>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="15 0 0 0">
                                        <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="Rank: "/>
                                        <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Rank}"/>
                                        <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text=" | Step: " Padding="10 0 0 0"/>
                                        <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Step}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
                <Label Classes="PrimaryText" Content="Discipline Free Talents" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="25"></Label>
                <ListBox ItemsSource="{Binding FreeTalents}" Background="Transparent" HorizontalAlignment="Right">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Talent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Name}"/>
                                <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text=" - Rank: " Padding="10 0 0 0"/>
                                <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Rank}"/>
                                <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text=" | Step: " Padding="10 0 0 0"/>
                                <TextBlock Classes="PrimaryDescriptionText" FontSize="20" Text="{Binding Step}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3">
                    <TextBlock Classes="PrimaryDescriptionText" Text="Available Optional Talents:" FontSize="25"/>
                    <ItemsControl ItemsSource="{Binding OptionalTalents}" FontSize="20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Classes="PrimaryRadioButton"
                                    GroupName="NoviceOptionTalents"
                                    Content="{Binding}"
                                    Command="{Binding $parent[ItemsControl].((vm:CharacterCustomizationsViewModel)DataContext).SelectNoviceOptionTalentCommand}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>
        <Border Classes="background" CornerRadius="30">
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, *">
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Classes="PrimarySubHeader" Content="Talent Description" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Label Classes="PrimaryText" Content="Governing Attribute:" Padding="10 5 5 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding CurrentTalent.Step, TargetNullValue='No Value'}" Padding="3 5 0 0"/>
                        <Label Classes="PrimaryText" Content="Strain:" Padding="75 5 5 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding CurrentTalent.Strain, TargetNullValue='No Value'}" Padding="3 5 0 0"/>
                        <Label Classes="PrimaryText" Content="Action:" Padding="75 5 5 0"/>
                        <TextBlock Classes="PrimaryDescriptionText" Text="{Binding CurrentTalent.Action, TargetNullValue='No Value'}" Padding="3 5 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
    
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
    
                    </StackPanel>
                    <Label Classes="PrimaryText" Content="Description:" Padding="10 5 5 1"/>
                    <TextBlock Classes="PrimaryDescriptionText" Text="{Binding CurrentTalent.Description, TargetNullValue='No Value'}" TextWrapping="Wrap" Padding="20 5 5 15"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
