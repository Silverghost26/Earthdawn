<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
            <StackPanel>
                <Button Classes="navigation"
                    Width="50"
                    Height="30">
                    <Image Source="/Assets/Icons/silver_left_arrow.png" />
                </Button>
                <Button Content="HelloWorld"> 
                </Button>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="4,4"/>
        <Setter Property="Background" Value="{DynamicResource ButtonNavBackground}"/>
    </Style>
    
    <Style Selector="Button.navigation">
        <Setter Property="Background" Value="{DynamicResource ButtonNavBackground}"/>
    </Style>
    
    <Style Selector="Button.navigation:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBackgroundHover}"/>
    </Style>    
</Styles>
